<Window x:Class="TNovParking.ParkMarkWPF"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TNovParking"
             mc:Ignorable="d" Width="290"
        d:DataContext="{d:DesignInstance local:ParkMarkViewModel}"
            WindowStartupLocation="CenterScreen" 
                        AllowsTransparency="True"
Background="Transparent"
            ResizeMode="NoResize" WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TNovCommon;component/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
          ResizeBorderThickness="5"
          GlassFrameThickness="0"
          CornerRadius="12"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="12"
    Background="White"
    BorderBrush="#FF008E43"
    BorderThickness="1">
        <Grid>
            <!-- Верхняя панель (кастомный заголовок) -->
            <Border Height="30" CornerRadius="12 12 0 0"
    Background="#FF008E43" 
    VerticalAlignment="Top"
    MouseDown="Border_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RoundButtonStyle}" 
Click="escButton_Click" Content="✕"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="5,0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource RoundButtonStyle2}" 
Click="HelpButton_Click" Content="?"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <TextBlock Text="Парковки Марка-Позиция" 
Foreground="White"
VerticalAlignment="Center"
Margin="10,0"/>
                </StackPanel>

            </Border>


            <!-- Основное содержимое -->
            <Border Margin="0,30,0,0">

                <StackPanel VerticalAlignment="Center" Margin="5">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Margin="5" Text="Сценарий:" TextWrapping="Wrap" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding scenariolist}"
            SelectedItem="{Binding Path=scenario, Mode=TwoWay}"
            SelectedIndex = "0"
            Margin="5" MinWidth="191"
        />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Name="text1" Margin="5" Text="Префикс A_Позиции:" TextWrapping="Wrap" />
                        <TextBox Name="textBox1" Text="{Binding prefix}" Margin="5" TextAlignment="Center" TextWrapping="Wrap" MinWidth="133" BorderBrush="#CCCCCC"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <CheckBox x:Name="checkBox1" IsThreeState="False" IsChecked="{Binding all}" Content="Сквозное заполнение целевого параметра" Margin="5" BorderBrush="#CCCCCC"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Отмена" x:Name="escButton" IsCancel="True" Click="escButton_Click" MinWidth="60" MinHeight="25" Margin="5" Style="{StaticResource CustomButtonStyle}" />
                        <Button Content="Запуск" x:Name="acceptButton" IsDefault="True" Click="acceptButton_Click"  MinWidth="120" MinHeight="25" Margin="5" Style="{StaticResource CustomButtonStyle}" />
                    </StackPanel>
                </StackPanel>

            </Border>
        </Grid>
    </Border>

</Window>
